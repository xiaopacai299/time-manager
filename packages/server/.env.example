NODE_ENV=development
PORT=3000

# 本机开发：先 `pnpm run db:up` 启动 Docker 里的 Postgres，再填下面这一行（与 docker-compose 里账号一致）
# postgresql://POSTGRES_USER:POSTGRES_PASSWORD@localhost:5432/POSTGRES_DB?schema=public
DATABASE_URL=postgresql://timemanger:timemanger@localhost:5432/timemanger?schema=public

# 各至少 32 字符（不要用 <...> 这种短占位）；生产环境请使用强随机值
JWT_ACCESS_SECRET=local_development_only_do_not_use_in_production_access_secret
JWT_REFRESH_SECRET=local_development_only_do_not_use_in_production_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

RATE_LIMIT_AUTH=5
RATE_LIMIT_SYNC=60
