{
  "name": "@time-manger/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @time-manger/shared build && pnpm run prisma:generate",
    "dev": "tsx watch src/index.ts",
    "build": "pnpm dlx prisma@5.22.0 generate --schema prisma/schema.prisma && tsc -p .",
    "start": "node dist/index.js",
    "prisma:generate": "pnpm dlx prisma@5.22.0 generate --schema prisma/schema.prisma",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "echo \"(server uses tsc for lint)\"",
    "test": "tsx --test src/index.test.ts tests/integration.test.ts",
    "db:generate": "pnpm dlx prisma@5.22.0 generate --schema prisma/schema.prisma",
    "db:migrate": "pnpm dlx prisma@5.22.0 migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "pnpm dlx prisma@5.22.0 migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@time-manger/shared": "workspace:*",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.0",
    "jose": "^6.2.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.10",
    "@types/supertest": "^6.0.2",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "5.7.3"
  }
}
