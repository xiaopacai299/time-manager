{
  "name": "@time-manger/shared",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p .",
    "build:watch": "tsc -p . --watch",
    "typecheck": "tsc -p . --noEmit",
    "lint": "echo \"(shared uses tsc for lint)\"",
    "test": "node --test --experimental-strip-types src/**/*.test.ts"
  },
  "devDependencies": {
    "typescript": "5.7.3"
  }
}
